{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "request-pilot",
  "mainBinaryName": "request-pilot",
  "version": "0.0.0",
  "identifier": "com.samtv12345.dev",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "center": true,
        "visible": false,
        "title": "request-pilot",
        "dragDropEnabled": false,
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "useHttpsScheme": true
      },
      {
        "width": 400,
        "height": 200,
        "center": true,
        "transparent": true,
        "decorations": false,
        "url": "splashscreen.html",
        "label": "splashscreen",
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}